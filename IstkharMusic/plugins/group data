import time
from datetime import datetime
from asyncio import sleep

from pyrogram import filters, enums
from pyrogram.types import Message

from MAHIMUSIC import app

# --- EXISTING GROUPDATA FEATURE ---

@app.on_message(~filters.private & filters.command(["groupdata"]), group=2)
async def groupdata_handler(client, message: Message):
    start_time = time.perf_counter()

    try:
        member = await client.get_chat_member(message.chat.id, message.from_user.id)
        if member.status not in (enums.ChatMemberStatus.ADMINISTRATOR, enums.ChatMemberStatus.OWNER):
            warn = await message.reply_text("🚫 ONLY ADMINS CAN USE THIS!")
            await sleep(5)
            return await warn.delete()
    except Exception:
        warn = await message.reply_text("🚫 Admin check failed.")
        await sleep(5)
        return await warn.delete()

    status = await message.reply_text("🔍 Gathering group stats...")

    try:
        total_members = await client.get_chat_members_count(message.chat.id)
    except Exception:
        total_members = 0

    stats = {
        "banned": 0,
        "deleted": 0,
        "bots": 0,
        "premium": 0,
        "restricted": 0,
        "fake": 0,
        "admins": 0,
        "uncached": 0,
    }

    try:
        async for _ in client.get_chat_members(message.chat.id, filter=enums.ChatMembersFilter.BANNED):
            stats["banned"] += 1
    except Exception:
        pass

    try:
        async for _ in client.get_chat_members(message.chat.id, filter=enums.ChatMembersFilter.ADMINISTRATORS):
            stats["admins"] += 1
    except Exception:
        pass

    try:
        async for member in client.get_chat_members(message.chat.id):
            u = member.user

            if u.is_deleted:
                stats["deleted"] += 1
                continue

            if u.is_bot:
                stats["bots"] += 1
                continue

            if getattr(u, "is_premium", False):
                stats["premium"] += 1

            if getattr(member, "status", None) == enums.ChatMemberStatus.RESTRICTED:
                stats["restricted"] += 1

            if (u.username is None) and (u.first_name is not None) and (len(u.first_name) <= 2):
                stats["fake"] += 1
            else:
                stats["uncached"] += 1
    except Exception:
        pass

    end_time = time.perf_counter()
    took = f"{end_time - start_time:.2f}"
    now = datetime.now().strftime("%d %b %Y • %H:%M")
    title = message.chat.title or "This Group"

    text = (
        f"<b>📊 Group Data Report</b>\n"
        f"<i>{now}</i>\n"
        f"────────────────────────\n"
        f"<b>🧩 Group</b>: {title}\n"
        f"<b>👥 Members</b>: <code>{total_members:,}</code>\n"
        f"────────────────────────\n"
        f"<b>👮 Admins</b>: <code>{stats['admins']:,}</code>\n"
        f"<b>🤖 Bots</b>: <code>{stats['bots']:,}</code>\n"
        f"<b>🧟 Zombies</b>: <code>{stats['deleted']:,}</code>\n"
        f"<b>🚫 Banned</b>: <code>{stats['banned']:,}</code>\n"
        f"<b>🎁 Premium</b>: <code>{stats['premium']:,}</code>\n"
        f"<b>🔒 Restricted</b>: <code>{stats['restricted']:,}</code>\n"
        f"<b>👻 Fake</b>: <code>{stats['fake']:,}</code>\n"
        f"────────────────────────\n"
        f"<b>⏱ Time taken</b>: <code>{took}s</code>"
    )

    await status.edit(
        text=text,
        parse_mode=enums.ParseMode.HTML,
        disable_web_page_preview=True,
    )


# --- NEW RANKCHAT FEATURE ---

# Dictionary to store message counts: {chat_id: {user_id: count}}
chat_ranks = {}

def get_rank_title(message_count: int) -> str:
    """Returns a title based on the user's message count."""
    if message_count < 10:
        return "Noob 👶"
    elif message_count < 50:
        return "Active Member 🗣"
    elif message_count < 100:
        return "Chatterbox 💬"
    elif message_count < 500:
        return "Veteran 🏅"
    elif message_count < 1000:
        return "Addict 📱"
    else:
        return "Legend 👑"

@app.on_message(filters.group & ~filters.bot, group=3)
async def count_messages(client, message: Message):
    """Listens to all group messages and increments the user's count."""
    if not message.from_user:
        return

    chat_id = message.chat.id
    user_id = message.from_user.id

    # Initialize nested dicts if they don't exist
    if chat_id not in chat_ranks:
        chat_ranks[chat_id] = {}
    if user_id not in chat_ranks[chat_id]:
        chat_ranks[chat_id][user_id] = 0

    # Increment message count
    chat_ranks[chat_id][user_id] += 1

@app.on_message(filters.command(["rank", "myrank"]) & filters.group)
async def check_rank(client, message: Message):
    """Allows users to check their rank or the rank of someone they reply to."""
    chat_id = message.chat.id
    
    # Determine whose rank to check
    target_user = message.from_user
    if message.reply_to_message and message.reply_to_message.from_user:
        target_user = message.reply_to_message.from_user
        
    user_id = target_user.id
    name = target_user.first_name or "User"

    # Fetch count (default to 0 if not found)
    count = chat_ranks.get(chat_id, {}).get(user_id, 0)
    rank_title = get_rank_title(count)

    text = (
        f"📊 **Chat Rank Info**\n"
        f"──────────────────\n"
        f"👤 **User:** {name}\n"
        f"💬 **Messages Sent:** `{count}`\n"
        f"🏆 **Current Level:** {rank_title}"
    )
    
    await message.reply_text(text)
